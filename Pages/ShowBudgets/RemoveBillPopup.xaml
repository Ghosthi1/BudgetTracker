<?xml version="1.0" encoding="utf-8"?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="BudgetTracker.Pages.ShowBudgets.RemoveBillPopup">

    <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
            Padding="24"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 16"
            WidthRequest="320">
        <VerticalStackLayout Spacing="16">

            <Label Text="Remove Bill" FontAttributes="Bold" FontSize="18" />

            <CollectionView x:Name="BillsList" SelectionMode="Single" SelectionChanged="OnSelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,10" StrokeThickness="0" StrokeShape="RoundRectangle 8" Margin="0,0,0,4">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#D94A4A, Dark=#8A2C2C}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{Binding Name}" HorizontalOptions="Center" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelClicked"
                        BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#444}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Button Grid.Column="1" Text="Remove" Clicked="OnRemoveClicked"
                        BackgroundColor="{AppThemeBinding Light=#D94A4A, Dark=#8A2C2C}"
                        TextColor="White" />
            </Grid>

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>