<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BudgetTracker.Pages.ShowBudgets"
             x:Class="BudgetTracker.Pages.ShowBudgets.Budget">

    <ContentPage.Resources>
        <Style x:Key="HeaderCell" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="StrokeShape" Value="RoundRectangle 6" />
        </Style>
        <Style x:Key="HeaderLabel" TargetType="Label">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HorizontalOptions" Value="Center" />
        </Style>
        <Style x:Key="DataCell" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="StrokeShape" Value="RoundRectangle 6" />
        </Style>
        <Style x:Key="DataLabel" TargetType="Label">
            <Setter Property="HorizontalOptions" Value="Center" />
        </Style>
    </ContentPage.Resources>

    <VerticalStackLayout Padding="16" Spacing="12">

        <!-- User bar -->
        <Grid ColumnDefinitions="*,Auto">
            <Label Grid.Column="0"
                   Text="{Binding CurrentUserEmail, StringFormat='Logged in as {0}'}"
                   VerticalOptions="Center"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#555, Dark=#AAA}" />
            <Button Grid.Column="1"
                    Text="Log Out"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#D94A4A, Dark=#FF6B6B}"
                    FontSize="13"
                    Padding="8,4" />
        </Grid>

        <!-- Summary boxes -->
        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Border Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}"
                    Padding="16" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                <Label Text="{Binding TotalYearly, StringFormat='Yearly Total: ${0:F2}'}" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
            </Border>
            <Border Grid.Column="1"
                    BackgroundColor="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}"
                    Padding="16" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                <Label Text="{Binding TotalMonthly, StringFormat='Monthly Total: ${0:F2}'}" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
            </Border>
        </Grid>

        <!-- Column headers -->
        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6">
            <Border Grid.Column="0" Style="{StaticResource HeaderCell}">
                <Label Text="Name" Style="{StaticResource HeaderLabel}" />
            </Border>
            <Border Grid.Column="1" Style="{StaticResource HeaderCell}">
                <Label Text="Amount" Style="{StaticResource HeaderLabel}" />
            </Border>
            <Border Grid.Column="2" Style="{StaticResource HeaderCell}">
                <Label Text="Due" Style="{StaticResource HeaderLabel}" />
            </Border>
            <Border Grid.Column="3" Style="{StaticResource HeaderCell}">
                <Label Text="Monthly" Style="{StaticResource HeaderLabel}" />
            </Border>
            <Border Grid.Column="4" Style="{StaticResource HeaderCell}">
                <Label Text="Yearly" Style="{StaticResource HeaderLabel}" />
            </Border>
        </Grid>
        
        <!-- Bill rows -->
        <CollectionView ItemsSource="{Binding Bills}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6">
                        <Border Grid.Column="0" Style="{StaticResource DataCell}">
                            <Label Text="{Binding Name}" Style="{StaticResource DataLabel}" />
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource DataCell}">
                            <Label Text="{Binding Amount, StringFormat='${0:F2}'}" Style="{StaticResource DataLabel}" />
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource DataCell}">
                            <Label Text="{Binding DueDay, StringFormat='{0}th'}" Style="{StaticResource DataLabel}" />
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource DataCell}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding Frequency}" Value="Monthly">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{Binding MonthlyEquivalent, StringFormat='${0:F2}'}" Style="{StaticResource DataLabel}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Frequency}" Value="Monthly">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                        <Border Grid.Column="4" Style="{StaticResource DataCell}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding Frequency}" Value="Yearly">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{Binding YearlyEquivalent, StringFormat='${0:F2}'}" Style="{StaticResource DataLabel}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Frequency}" Value="Yearly">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Action buttons -->
        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Grid.Column="0" Text="+ Add Bill"
                    Clicked="OnAddBillClicked"
                    BackgroundColor="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}"
                    TextColor="White"
                    CornerRadius="10" />
            <Button Grid.Column="1" Text="- Remove Bill"
                    Clicked="OnRemoveBillClicked"
                    BackgroundColor="{AppThemeBinding Light=#D94A4A, Dark=#8A2C2C}"
                    TextColor="White"
                    CornerRadius="10" />
        </Grid>

    </VerticalStackLayout>

</ContentPage>