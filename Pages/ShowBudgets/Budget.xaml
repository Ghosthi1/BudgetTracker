<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetTracker.Pages.ShowBudgets.Budget">

    <ContentPage.Resources>
        <Style x:Key="HeaderCell" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="StrokeShape" Value="RoundRectangle 6" />
        </Style>
        <Style x:Key="HeaderLabel" TargetType="Label">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HorizontalOptions" Value="Center" />
        </Style>
        <Style x:Key="DataCell" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="StrokeShape" Value="RoundRectangle 6" />
        </Style>
        <Style x:Key="DataLabel" TargetType="Label">
            <Setter Property="HorizontalOptions" Value="Center" />
        </Style>
    </ContentPage.Resources>

    <VerticalStackLayout Padding="16" Spacing="12">

        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Border Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}"
                    Padding="16" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                <Label Text="Total Yearly" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
            </Border>
            <Border Grid.Column="1"
                    BackgroundColor="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}"
                    Padding="16" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                <Label Text="Total Monthly" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
            </Border>
        </Grid>

        <Grid RowDefinitions="Auto,Auto,Auto"
              ColumnDefinitions="*,*,*"
              RowSpacing="6"
              ColumnSpacing="6">

        <!-- Row 0 — Header -->
        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource HeaderCell}">
            <Label Text="Name" Style="{StaticResource HeaderLabel}" />
        </Border>
        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource HeaderCell}">
            <Label Text="Amount" Style="{StaticResource HeaderLabel}" />
        </Border>
        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource HeaderCell}">
            <Label Text="Due" Style="{StaticResource HeaderLabel}" />
        </Border>

        <!-- Row 1 -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource DataCell}">
            <Label Text="Netflix" Style="{StaticResource DataLabel}" />
        </Border>
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource DataCell}">
            <Label Text="$17.99" Style="{StaticResource DataLabel}" />
        </Border>
        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource DataCell}">
            <Label Text="15th" Style="{StaticResource DataLabel}" />
        </Border>

        <!-- Row 2 -->
        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource DataCell}">
            <Label Text="Spotify" Style="{StaticResource DataLabel}" />
        </Border>
        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource DataCell}">
            <Label Text="$11.99" Style="{StaticResource DataLabel}" />
        </Border>
        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource DataCell}">
            <Label Text="1st" Style="{StaticResource DataLabel}" />
        </Border>

        </Grid>

    </VerticalStackLayout>

</ContentPage>