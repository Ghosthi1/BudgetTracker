<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BudgetTracker.Pages.ShowBudgets"
             xmlns:models="clr-namespace:BudgetTracker.Models"
             x:Class="BudgetTracker.Pages.ShowBudgets.Budget">


    <VerticalStackLayout Padding="16" Spacing="12">

        <!-- User bar -->
        <Grid ColumnDefinitions="*,Auto">
            <Label Grid.Column="0"
                   Text="{Binding CurrentUserEmail, StringFormat='Logged in as {0}'}"
                   VerticalOptions="Center"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#555, Dark=#AAA}" />
            <Button Grid.Column="1"
                    Text="Log Out"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#D94A4A, Dark=#FF6B6B}"
                    FontSize="13"
                    Padding="8,4" />
        </Grid>

        <!-- Summary boxes -->
        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Border Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}"
                    Padding="16" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                <Label Text="{Binding TotalYearly, StringFormat='Yearly Total: ${0:F2}'}" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
            </Border>
            <Border Grid.Column="1"
                    BackgroundColor="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}"
                    Padding="16" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                <Label Text="{Binding TotalMonthly, StringFormat='Monthly Total: ${0:F2}'}" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
            </Border>
        </Grid>

        <!-- Bill rows -->
        <CollectionView ItemsSource="{Binding Bills}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Bill">
                    <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Padding="16,12"
                            Margin="0,0,0,0">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">

                            <!-- Row 1: Name + frequency badge -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F0F0F0}"
                                       VerticalOptions="Center" />
                                <Border Grid.Column="1"
                                        Padding="8,3"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 20"
                                        VerticalOptions="Center">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding Frequency}" Value="Monthly">
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding Frequency}" Value="Yearly">
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#5BA85A, Dark=#2E5E2D}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Frequency}" Value="Monthly">
                                                <Setter Property="Text" Value="Monthly" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Frequency}" Value="Yearly">
                                                <Setter Property="Text" Value="Yearly" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </Grid>

                            <!-- Row 2: Category -->
                            <Label Grid.Row="1"
                                   Text="{Binding Category}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}" />

                            <!-- Row 3: Amount + due day -->
                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                <VerticalStackLayout Grid.Column="0" Spacing="1">
                                    <Label Text="{Binding Amount, StringFormat='${0:F2}'}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F0F0F0}" />
                                    <Label FontSize="11"
                                           TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Frequency}" Value="Monthly">
                                                <Setter Property="Text" Value="{Binding YearlyEquivalent, StringFormat='${0:F2}/yr'}" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Frequency}" Value="Yearly">
                                                <Setter Property="Text" Value="{Binding MonthlyEquivalent, StringFormat='${0:F2}/mo'}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="{Binding DueDay, StringFormat='Due: {0}th'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                                       VerticalOptions="Center" />
                            </Grid>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Action buttons -->
        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Grid.Column="0" Text="+ Add Bill"
                    Clicked="OnAddBillClicked"
                    BackgroundColor="{AppThemeBinding Light=#4A90D9, Dark=#2C5F8A}"
                    TextColor="White"
                    CornerRadius="10" />
            <Button Grid.Column="1" Text="- Remove Bill"
                    Clicked="OnRemoveBillClicked"
                    BackgroundColor="{AppThemeBinding Light=#D94A4A, Dark=#8A2C2C}"
                    TextColor="White"
                    CornerRadius="10" />
        </Grid>

    </VerticalStackLayout>

</ContentPage>