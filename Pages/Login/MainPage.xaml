<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetTracker.MainPage">

    <ScrollView>
        <VerticalStackLayout 
            Padding="32" 
            Spacing="16" 
            VerticalOptions="Center" 
            MaximumWidthRequest="{OnIdiom Phone=600, Desktop=1000}"
            HorizontalOptions="Fill">

            <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" />
            <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" />

            <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False" />

            <Button Text="Sign In" Clicked="OnSignInClicked" />

            <Button Text="Temp next page" Clicked="OnNextPageClicked" />
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
